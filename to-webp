#!/bin/bash

# Convert PNG, JPG, JPEG to WebP in current directory
for img in *.png *.jpg *.jpeg; do
  # Skip if no files match
  [ -e "$img" ] || continue

  output="${img%.*}.webp"

  echo "Converting $img → $output"
  
  # The '&& rm "$img"' tells the script: 
  # "If the previous command succeeded, delete the input file."
  cwebp -q 80 "$img" -o "$output" && rm "$img"
done

echo "Done. Originals have been removed."
